meta {
  name: Sign Up
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/auth/sign-up/email
  body: json
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "Example User",
    "email": "example@example.com",
    "password": "ChangeMe123!"
  }
}

assert {
  res.status: eq 200
}
